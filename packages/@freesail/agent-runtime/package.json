{
  "name": "@freesail/agent-runtime",
  "version": "0.8.4",
  "description": "Runtime library for building Freesail agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "a2ui",
    "freesail",
    "agent-driven ui",
    "generative ui",
    "ai agent"
  ],
  "author": {
    "name": "Thendral AI Ltd",
    "email": "support@thendral.ai",
    "url": "https://www.thendral.ai"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0",
    "@freesail/logger": "^0.8.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
