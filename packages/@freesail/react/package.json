{
  "name": "@freesail/react",
  "version": "0.6.0",
  "description": "React implementation for Freesail - Agent-driven UI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "a2ui",
    "freesail",
    "agent-driven ui",
    "generative ui",
    "ai agent"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@freesail/core": "^0.6.0",
    "vite": "7.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vitest": "^4.0.18"
  },
  "author": {
    "name": "Thendral AI Ltd",
    "email": "support@thendral.ai",
    "url": "https://www.thendral.ai"
  },
  "contributors": [
    "Shanmugam Sudalaimuthu"
  ],
  "license": "MIT"
}
