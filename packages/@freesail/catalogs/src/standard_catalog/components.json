{
  "components": {
    "Image": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays an image. Key properties: url (required), fit (contain/cover/fill/none/scale-down), variant (icon/avatar/smallFeature/mediumFeature/largeFeature/header).",
          "properties": {
            "component": {
              "const": "Image"
            },
            "url": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The URL of the image to display."
            },
            "fit": {
              "type": "string",
              "description": "Specifies how the image should be resized to fit its container. This corresponds to the CSS 'object-fit' property.",
              "enum": [
                "contain",
                "cover",
                "fill",
                "none",
                "scale-down"
              ]
            },
            "variant": {
              "type": "string",
              "description": "A hint for the image size and style.",
              "enum": [
                "icon",
                "avatar",
                "smallFeature",
                "mediumFeature",
                "largeFeature",
                "header"
              ]
            }
          },
          "required": [
            "component",
            "url"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Video": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Plays a video. Key properties: url (required), embed (set to true for YouTube/Vimeo URLs).",
          "properties": {
            "component": {
              "const": "Video"
            },
            "url": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The URL of the video to display."
            },
            "embed": {
              "type": "boolean",
              "description": "When true, the video is rendered inside an iframe. This MUST be set to true for third-party sources such as YouTube (youtube.com, youtu.be) and Vimeo (vimeo.com). When false or omitted, a native video player is used, which only works with direct video file URLs (e.g. .mp4, .webm).",
              "default": false
            }
          },
          "required": [
            "component",
            "url"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "AudioPlayer": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "An audio player that supports direct audio file URLs and embedded third-party players (e.g. Spotify, SoundCloud).",
          "properties": {
            "component": {
              "const": "AudioPlayer"
            },
            "url": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The URL of the audio to be played."
            },
            "description": {
              "description": "A description of the audio, such as a title or summary.",
              "$ref": "../common/common_types.json#/$defs/DynamicString"
            },
            "embed": {
              "type": "boolean",
              "description": "When true, the audio is rendered inside an iframe embed player. This MUST be set to true for third-party sources such as Spotify (open.spotify.com) and SoundCloud (soundcloud.com). When false or omitted, a native audio player is used, which only works with direct audio file URLs (e.g. .mp3, .wav).",
              "default": false
            }
          },
          "required": [
            "component",
            "url"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "List": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A scrollable list that lays out children vertically or horizontally, with optional alignment control.",
          "properties": {
            "component": {
              "const": "List"
            },
            "children": {
              "description": "Defines the children. Use an array of strings for a fixed set of children, or a template object to generate children from a data list.",
              "$ref": "../common/common_types.json#/$defs/ChildList"
            },
            "direction": {
              "type": "string",
              "description": "The direction in which the list items are laid out.",
              "enum": [
                "vertical",
                "horizontal"
              ]
            },
            "align": {
              "type": "string",
              "description": "Defines the alignment of children along the cross axis.",
              "enum": [
                "start",
                "center",
                "end",
                "stretch"
              ]
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "TabGroup": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A tabbed container that shows one Tab child at a time. Children must be Tab components.",
          "properties": {
            "component": {
              "const": "TabGroup"
            },
            "children": {
              "type": "array",
              "items": {
                "$ref": "../common/common_types.json#/$defs/ComponentId"
              },
              "description": "Array of Tab component IDs. Do NOT define components inline."
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Tab": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A single tab within a TabGroup. Has a title and a child component.",
          "properties": {
            "component": {
              "const": "Tab"
            },
            "title": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The tab title displayed in the tab bar."
            },
            "child": {
              "$ref": "../common/common_types.json#/$defs/ComponentId",
              "description": "The ID of the child component. Do NOT define the component inline."
            }
          },
          "required": [
            "component",
            "title",
            "child"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Divider": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A visual separator line. Key properties: axis (horizontal/vertical, default horizontal).",
          "properties": {
            "component": {
              "const": "Divider"
            },
            "axis": {
              "type": "string",
              "description": "The orientation of the divider.",
              "enum": [
                "horizontal",
                "vertical"
              ],
              "default": "horizontal"
            }
          },
          "required": [
            "component"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Dropdown": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "$ref": "../common/common_types.json#/$defs/Checkable"
        },
        {
          "type": "object",
          "description": "A dropdown (select) component for choosing a single option from a list.",
          "properties": {
            "component": {
              "const": "Dropdown"
            },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The label for the dropdown."
            },
            "hideLabel": {
              "type": "boolean",
              "description": "When true, hides the label above the dropdown. Use this when the Dropdown is inside a GridLayout — the column headers already act as labels.",
              "default": false
            },
            "placeholder": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Placeholder text shown when no option is selected."
            },
            "options": {
              "description": "The list of available options to choose from. Can be a literal array or a data binding to a list in the data model.",
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "label": {
                        "description": "The text to display for this option.",
                        "$ref": "../common/common_types.json#/$defs/DynamicString"
                      },
                      "value": {
                        "type": "string",
                        "description": "The stable value associated with this option."
                      }
                    },
                    "required": [
                      "label",
                      "value"
                    ],
                    "additionalProperties": false
                  }
                },
                {
                  "$ref": "../common/common_types.json#/$defs/DataBinding"
                }
              ]
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The currently selected value. This should be bound to a string in the data model."
            }
          },
          "required": [
            "component",
            "options",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "CheckBox": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "$ref": "../common/common_types.json#/$defs/Checkable"
        },
        {
          "type": "object",
          "description": "A checkbox toggle for boolean values. Key properties: label (required), value (required, data binding for the checked state).",
          "properties": {
            "component": {
              "const": "CheckBox"
            },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The text to display next to the checkbox."
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicBoolean",
              "description": "The current state of the checkbox (true for checked, false for unchecked)."
            }
          },
          "required": [
            "component",
            "label",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Slider": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "$ref": "../common/common_types.json#/$defs/Checkable"
        },
        {
          "type": "object",
          "description": "A slider for selecting a numeric value within a range. Key properties: value (required), min (required), max (required), label.",
          "properties": {
            "component": {
              "const": "Slider"
            },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The label for the slider."
            },
            "min": {
              "type": "number",
              "description": "The minimum value of the slider."
            },
            "max": {
              "type": "number",
              "description": "The maximum value of the slider."
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "The current value of the slider."
            }
          },
          "required": [
            "component",
            "value",
            "min",
            "max"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Markdown": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Renders rich Markdown content. Use this for multi-paragraph text, formatted content, or when HTML-like structure is needed. Key properties: text (required, the markdown string to render).",
          "properties": {
            "component": {
              "const": "Markdown"
            },
            "text": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The markdown content to display."
            }
          },
          "required": [
            "component",
            "text"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "GridLayout": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays tabular data with styled rows (alternating backgrounds, borders). Can also be used as a structured grid layout without headers. Follows A2UI composition: Grid provides the grid structure and optional header row, while the row content is composed using existing Row and Text components via the children template. Key properties: headers (optional, array of column header strings; determines column count), children (required, ChildList template pointing to a Row component and a data path), rowPadding (controls the padding of each cell; default '10px 16px'; use to add vertical spacing between rows, e.g. '14px 16px'). IMPORTANT: Row padding is controlled by rowPadding on the GridLayout, not by padding on the child Row components. IMPORTANT: When placing TextField or Dropdown components inside a GridLayout, always set hideLabel: true on each one — the column headers already serve as labels, and showing them again inside each cell makes rows unnecessarily tall.",
          "properties": {
            "component": {
              "const": "GridLayout"
            },
            "headers": {
              "type": "array",
              "items": {
                "$ref": "../common/common_types.json#/$defs/DynamicString"
              },
              "description": "The column header labels displayed in the header row."
            },
            "children": {
              "description": "Defines the row content. Use a template object { componentId, path } to generate rows from a data list. The componentId should reference a Row component containing Text components for each column.",
              "$ref": "../common/common_types.json#/$defs/ChildList"
            },
            "rowPadding": {
              "description": "CSS padding applied to every cell in each data row. Use this to control row height and vertical spacing. Defaults to '10px 16px'. Example: '16px' for taller rows with more breathing room.",
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "default": "10px 16px"
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "BarChart": {
      "type": "object",
      "allOf": [
        { "$ref": "../common/common_types.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "description": "Renders a bar chart from an array of data points. Each data point has a label and value. The chart auto-scales to fit. Use orientation 'horizontal' for long labels or many categories.",
          "properties": {
            "component": { "const": "BarChart" },
            "title": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Optional chart title displayed above the chart."
            },
            "data": {
              "description": "Array of data points. Each item has a 'label' (string) and 'value' (number), and optionally a 'color' (CSS color string) to override the default bar color for that item.",
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "label": { "type": "string" },
                      "value": { "type": "number" },
                      "color": { "type": "string" }
                    },
                    "required": ["label", "value"]
                  },
                  "minItems": 1
                },
                {
                  "$ref": "../common/common_types.json#/$defs/DataBinding"
                }
              ]
            },
            "orientation": {
              "type": "string",
              "description": "Bar direction. 'vertical' = bars grow upward, 'horizontal' = bars grow rightward.",
              "enum": ["vertical", "horizontal"],
              "default": "vertical"
            },
            "color": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Default bar color (CSS). Individual data items can override with their own 'color'."
            },
            "showValues": {
              "$ref": "../common/common_types.json#/$defs/DynamicBoolean",
              "description": "Whether to display the numeric value on each bar.",
              "default": true
            },
            "height": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Chart height in pixels.",
              "default": 300
            }
          },
          "required": ["component", "data"]
        }
      ],
      "unevaluatedProperties": false
    },
    "LineChart": {
      "type": "object",
      "allOf": [
        { "$ref": "../common/common_types.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "description": "Renders a line chart from an array of data points. Supports optional area fill and data point dots. Good for showing trends over time.",
          "properties": {
            "component": { "const": "LineChart" },
            "title": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Optional chart title displayed above the chart."
            },
            "data": {
              "description": "Array of data points. Each item has a 'label' (string) and 'value' (number).",
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "label": { "type": "string" },
                      "value": { "type": "number" }
                    },
                    "required": ["label", "value"]
                  },
                  "minItems": 2
                },
                {
                  "$ref": "../common/common_types.json#/$defs/DataBinding"
                }
              ]
            },
            "color": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Line color (CSS).",
              "default": "#2563eb"
            },
            "showDots": {
              "$ref": "../common/common_types.json#/$defs/DynamicBoolean",
              "description": "Whether to show data point circles on the line.",
              "default": true
            },
            "showArea": {
              "$ref": "../common/common_types.json#/$defs/DynamicBoolean",
              "description": "Whether to fill the area under the line with a translucent gradient.",
              "default": false
            },
            "height": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Chart height in pixels.",
              "default": 300
            }
          },
          "required": ["component", "data"]
        }
      ],
      "unevaluatedProperties": false
    },
    "PieChart": {
      "type": "object",
      "allOf": [
        { "$ref": "../common/common_types.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "description": "Renders a pie or donut chart from an array of segments. Each segment has a label and value. Colors are auto-assigned if not provided.",
          "properties": {
            "component": { "const": "PieChart" },
            "title": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Optional chart title displayed above the chart."
            },
            "data": {
              "description": "Array of segments. Each item has a 'label' (string) and 'value' (number), and optionally a 'color' (CSS color string).",
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "label": { "type": "string" },
                      "value": { "type": "number" },
                      "color": { "type": "string" }
                    },
                    "required": ["label", "value"]
                  },
                  "minItems": 1
                },
                {
                  "$ref": "../common/common_types.json#/$defs/DataBinding"
                }
              ]
            },
            "donut": {
              "$ref": "../common/common_types.json#/$defs/DynamicBoolean",
              "description": "If true, renders as a donut chart with a hollow center.",
              "default": false
            },
            "size": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Chart diameter in pixels.",
              "default": 250
            }
          },
          "required": ["component", "data"]
        }
      ],
      "unevaluatedProperties": false
    },
    "Sparkline": {
      "type": "object",
      "allOf": [
        { "$ref": "../common/common_types.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "description": "Renders a compact inline sparkline chart from an array of numbers. Use inside StatCard or alongside text to show a quick trend.",
          "properties": {
            "component": { "const": "Sparkline" },
            "values": {
              "description": "Array of numeric values representing the trend data.",
              "oneOf": [
                {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 2
                },
                {
                  "$ref": "../common/common_types.json#/$defs/DataBinding"
                }
              ]
            },
            "color": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Line color (CSS).",
              "default": "#2563eb"
            },
            "width": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Sparkline width in pixels.",
              "default": 120
            },
            "height": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Sparkline height in pixels.",
              "default": 32
            }
          },
          "required": ["component", "values"]
        }
      ],
      "unevaluatedProperties": false
    },
    "StatCard": {
      "type": "object",
      "allOf": [
        { "$ref": "../common/common_types.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "description": "Renders a KPI / summary statistic card with a large value, label, and optional trend indicator. Use multiple StatCards in a Row to create a dashboard header.",
          "properties": {
            "component": { "const": "StatCard" },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The metric label (e.g. 'Total Revenue', 'Active Users')."
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The formatted display value (e.g. '$12,340', '1.2k', '98%'). Use formatNumber or formatCurrency to produce this."
            },
            "trend": {
              "type": "string",
              "description": "Direction of the trend arrow.",
              "enum": ["up", "down", "neutral"]
            },
            "trendColor": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Color of the trend arrow."
            },
            "trendValue": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "The trend change text shown next to the arrow (e.g. '+12%', '-3.2%')."
            },
            "color": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Accent color for the card's left border and icon."
            },
            "children": {
              "$ref": "../common/common_types.json#/$defs/ChildList",
              "description": "Optional children rendered below the stat value (e.g. a Sparkline)."
            }
          },
          "required": ["component", "label", "value"]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "$defs": {
    "CatalogComponentCommon": {
      "type": "object",
      "properties": {
        "weight": {
          "type": "number",
          "description": "The relative weight of this component within a Row or Column. This is similar to the CSS 'flex-grow' property. Note: this may ONLY be set when the component is a direct descendant of a Row or Column."
        }
      }
    }
  }
}
