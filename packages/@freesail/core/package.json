{
  "name": "@freesail/core",
  "version": "0.4.6",
  "description": "Core TypeScript logic for Freesail - protocol definitions, parser, transport",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "vitest run",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "a2ui",
    "freesail",
    "agent-driven ui",
    "generative ui",
    "ai agent"
  ],
  "author": {
    "name": "Thendral AI Ltd",
    "email": "support@thendral.ai",
    "url": "https://www.thendral.ai"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "vite": "7.3.1"
  }
}
