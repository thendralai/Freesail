{
  "$schema": "./schemas/catalog-schema.json",
  "$id": "https://freesail.dev/catalogs/weather_catalog_v1.json",
  "title": "Weather Catalog",
  "description": "Weather-specific UI components for displaying forecasts, conditions, and alerts",
  "catalogId": "https://freesail.dev/catalogs/weather_catalog_v1.json",
  "components": {
    "WeatherCard": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A comprehensive weather summary card for a location. Key properties: location (required), temperature (required), condition (required, e.g. sunny/cloudy/rainy), unit (C/F, default C), humidity (0-100), windSpeed, windUnit (km/h/mph/m/s), feelsLike, background (CSS color override).",
          "properties": {
            "component": {
              "const": "WeatherCard"
            },
            "location": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "City or location name (e.g. 'London', 'New York'). Extract this from the user's request."
            },
            "temperature": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Current temperature value"
            },
            "unit": {
              "type": "string",
              "description": "Temperature unit(C or F)",
              "enum": [
                "C",
                "F"
              ],
              "default": "C"
            },
            "condition": {
              "type": "string",
              "description": "Weather condition",
              "enum": [
                "sunny",
                "cloudy",
                "partly-cloudy",
                "rainy",
                "stormy",
                "snowy",
                "foggy",
                "windy"
              ]
            },
            "humidity": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Humidity percentage (0-100)"
            },
            "windSpeed": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Wind speed value"
            },
            "windUnit": {
              "type": "string",
              "description": "Wind speed unit",
              "enum": [
                "km/h",
                "mph",
                "m/s"
              ],
              "default": "km/h"
            },
            "feelsLike": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Feels-like temperature"
            },
            "background": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Background color override",
              "default": "bgSurface"
            }
          },
          "required": [
            "component",
            "location",
            "temperature",
            "condition"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "ForecastRow": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A single row in a weather forecast, showing the day's conditions. Key properties: day (required, e.g. 'Mon', 'Today'), high (required), low (required), condition (required), unit (C/F, default C), precipitation (chance percentage 0-100).",
          "properties": {
            "component": {
              "const": "ForecastRow"
            },
            "day": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Day label (e.g. 'Mon', 'Tuesday', 'Today')"
            },
            "high": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "High temperature"
            },
            "low": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Low temperature"
            },
            "unit": {
              "type": "string",
              "description": "Temperature unit",
              "enum": [
                "C",
                "F"
              ],
              "default": "C"
            },
            "condition": {
              "type": "string",
              "description": "Weather condition for the day",
              "enum": [
                "sunny",
                "cloudy",
                "partly-cloudy",
                "rainy",
                "stormy",
                "snowy",
                "foggy",
                "windy"
              ]
            },
            "precipitation": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Precipitation chance percentage (0-100)"
            }
          },
          "required": [
            "component",
            "day",
            "high",
            "low",
            "condition"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "ForecastPanel": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A container panel that groups ForecastRow children into a titled forecast list. Key properties: children (required, array of ForecastRow IDs or a template), title (default 'Forecast').",
          "properties": {
            "component": {
              "const": "ForecastPanel"
            },
            "title": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Panel title (e.g. '5-Day Forecast')",
              "default": "Forecast"
            },
            "children": {
              "$ref": "./common/common_types.json#/$defs/ChildList",
              "description": "Defines the children. Use an array of strings for a fixed set of children, or a template object to generate children from a data list."
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "TemperatureDisplay": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Renders a temperature value with its unit symbol. Key properties: value (required, numeric temperature), unit (C/F, default C), size (sm/md/lg/xl, default lg), color (CSS color).",
          "properties": {
            "component": {
              "const": "TemperatureDisplay"
            },
            "value": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Temperature value"
            },
            "unit": {
              "type": "string",
              "description": "Temperature unit",
              "enum": [
                "C",
                "F"
              ],
              "default": "C"
            },
            "size": {
              "type": "string",
              "description": "Display size",
              "enum": [
                "sm",
                "md",
                "lg",
                "xl"
              ],
              "default": "lg"
            },
            "color": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Text color"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "WeatherIcon": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays a weather condition icon. Key properties: condition (required, e.g. sunny/cloudy/rainy/stormy/snowy/foggy/windy), size (sm/md/lg/xl, default md), animated (boolean, default false).",
          "properties": {
            "component": {
              "const": "WeatherIcon"
            },
            "condition": {
              "type": "string",
              "description": "Weather condition to display",
              "enum": [
                "sunny",
                "cloudy",
                "partly-cloudy",
                "rainy",
                "stormy",
                "snowy",
                "foggy",
                "windy"
              ]
            },
            "size": {
              "type": "string",
              "description": "Icon size",
              "enum": [
                "sm",
                "md",
                "lg",
                "xl"
              ],
              "default": "md"
            },
            "animated": {
              "$ref": "./common/common_types.json#/$defs/DynamicBoolean",
              "description": "Whether to use subtle animation",
              "default": false
            }
          },
          "required": [
            "component",
            "condition"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "WindIndicator": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays wind speed and direction. Key properties: speed (required), unit (km/h/mph/m/s, default km/h), direction (cardinal, e.g. N/NE/E/SE/S/SW/W/NW), gustSpeed.",
          "properties": {
            "component": {
              "const": "WindIndicator"
            },
            "speed": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Wind speed value"
            },
            "unit": {
              "type": "string",
              "description": "Wind speed unit",
              "enum": [
                "km/h",
                "mph",
                "m/s"
              ],
              "default": "km/h"
            },
            "direction": {
              "type": "string",
              "description": "Wind cardinal direction",
              "enum": [
                "N",
                "NE",
                "E",
                "SE",
                "S",
                "SW",
                "W",
                "NW"
              ]
            },
            "gustSpeed": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Gust speed value"
            }
          },
          "required": [
            "component",
            "speed"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "HumidityGauge": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A gauge that visualizes the current humidity level. Key properties: value (required, percentage 0-100), label (default 'Humidity').",
          "properties": {
            "component": {
              "const": "HumidityGauge"
            },
            "value": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "Humidity percentage (0-100)"
            },
            "label": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Label text",
              "default": "Humidity"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "UVIndex": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays the current UV index with a visual indicator. Key properties: value (required, 0-11+), label (default 'UV Index').",
          "properties": {
            "component": {
              "const": "UVIndex"
            },
            "value": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "UV index value (0-11+)"
            },
            "label": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Label text",
              "default": "UV Index"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "WeatherAlert": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays a weather alert or warning banner. Key properties: severity (required, info/advisory/watch/warning), title (required), message (alert description), expires (expiry time).",
          "properties": {
            "component": {
              "const": "WeatherAlert"
            },
            "severity": {
              "type": "string",
              "description": "Alert severity level",
              "enum": [
                "info",
                "advisory",
                "watch",
                "warning"
              ]
            },
            "title": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Alert title"
            },
            "message": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Alert description text"
            },
            "expires": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Expiry time (human-readable or ISO 8601)"
            }
          },
          "required": [
            "component",
            "severity",
            "title"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "SunriseSunset": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Shows sunrise and sunset times with an optional sun position indicator. Key properties: sunrise (required, e.g. '6:32 AM'), sunset (required, e.g. '7:15 PM'), currentTime (for positioning the sun indicator).",
          "properties": {
            "component": {
              "const": "SunriseSunset"
            },
            "sunrise": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Sunrise time (e.g. '6:32 AM')"
            },
            "sunset": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Sunset time (e.g. '7:15 PM')"
            },
            "currentTime": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Current time for positioning the sun indicator"
            }
          },
          "required": [
            "component",
            "sunrise",
            "sunset"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "AirQuality": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays the Air Quality Index (AQI) with an optional primary pollutant. Key properties: value (required, AQI 0-500), label (default 'Air Quality'), pollutant (e.g. 'PM2.5', 'O3').",
          "properties": {
            "component": {
              "const": "AirQuality"
            },
            "value": {
              "$ref": "./common/common_types.json#/$defs/DynamicNumber",
              "description": "AQI value (0-500)"
            },
            "label": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Label text",
              "default": "Air Quality"
            },
            "pollutant": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "Primary pollutant (e.g. 'PM2.5', 'O3')"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Row": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A layout component that arranges its children horizontally. To create a grid layout, nest Columns within this Row. Key properties: children (required), gap (spacing between children, default '8px'), padding, justify (start/center/end/spaceBetween/spaceAround/spaceEvenly/stretch), align (start/center/end/stretch; controls vertical alignment).",
          "properties": {
            "component": {
              "const": "Row"
            },
            "children": {
              "description": "Defines the children. Use an array of strings for a fixed set of children, or a template object to generate children from a data list. Children cannot be defined inline, they must be referred to by ID.",
              "$ref": "./common/common_types.json#/$defs/ChildList"
            },
            "gap": {
              "description": "The spacing between children.",
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "default": "8px"
            },
            "padding": {
              "description": "Padding around the content.",
              "$ref": "./common/common_types.json#/$defs/DynamicString"
            },
            "justify": {
              "type": "string",
              "description": "Defines the arrangement of children along the main axis (horizontally). Use 'spaceBetween' to push items to the edges, or 'start'/'end'/'center' to pack them together.",
              "enum": [
                "center",
                "end",
                "spaceAround",
                "spaceBetween",
                "spaceEvenly",
                "start",
                "stretch"
              ]
            },
            "align": {
              "type": "string",
              "description": "Defines the alignment of children along the cross axis (vertically). This is similar to the CSS 'align-items' property, but uses camelCase values (e.g., 'start').",
              "enum": [
                "start",
                "center",
                "end",
                "stretch"
              ]
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Column": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A layout component that arranges its children vertically. To create a grid layout, nest Rows within this Column. Key properties: children (required), gap (spacing between children, default '8px'), padding, justify (start/center/end/spaceBetween/spaceAround/spaceEvenly/stretch), align (start/center/end/stretch; controls horizontal alignment of children; default is 'start'; set to 'stretch' for list layouts where children should fill the full width).",
          "properties": {
            "component": {
              "const": "Column"
            },
            "children": {
              "description": "Defines the children. Use an array of strings for a fixed set of children, or a template object to generate children from a data list. Children cannot be defined inline, they must be referred to by ID.",
              "$ref": "./common/common_types.json#/$defs/ChildList"
            },
            "gap": {
              "description": "The spacing between children.",
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "default": "8px"
            },
            "padding": {
              "description": "Padding around the content.",
              "$ref": "./common/common_types.json#/$defs/DynamicString"
            },
            "justify": {
              "type": "string",
              "description": "Defines the arrangement of children along the main axis (vertically). Use 'spaceBetween' to push items to the edges (e.g. header at top, footer at bottom), or 'start'/'end'/'center' to pack them together.",
              "enum": [
                "start",
                "center",
                "end",
                "spaceBetween",
                "spaceAround",
                "spaceEvenly",
                "stretch"
              ]
            },
            "align": {
              "type": "string",
              "description": "Defines the alignment of children along the cross axis (horizontally). This is similar to the CSS 'align-items' property.",
              "enum": [
                "center",
                "end",
                "start",
                "stretch"
              ]
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Card": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A styled container with border, shadow, and rounded corners. To make cards stretch to fill their parent's width, either set width to '100%' on the Card, or set align to 'stretch' on the parent Column. Key properties: child (required, ID of the single child component), padding (default '16px'), width, height, background (CSS color value to fill the card, e.g. '#22c55e', 'red', 'rgba(0,0,0,0.5)').",
          "properties": {
            "component": {
              "const": "Card"
            },
            "padding": {
              "description": "Padding inside the card.",
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "default": "16px"
            },
            "width": {
              "description": "The width of the card.",
              "$ref": "./common/common_types.json#/$defs/DynamicString"
            },
            "height": {
              "description": "The height of the card.",
              "$ref": "./common/common_types.json#/$defs/DynamicString"
            },
            "background": {
              "$ref": "./common/common_types.json#/$defs/DynamicString",
              "description": "A CSS color value for the card's background fill. Accepts any valid CSS color, e.g. hex ('#22c55e'), named ('red'), rgb/rgba, hsl. Defaults to the theme surface color."
            },
            "child": {
              "$ref": "./common/common_types.json#/$defs/ComponentId",
              "description": "The ID of the single child component to be rendered inside the card. To display multiple elements, you MUST wrap them in a layout component (like Column or Row) and pass that container's ID here. Do NOT pass multiple IDs or a non-existent ID. Do NOT define the child component inline."
            }
          },
          "required": [
            "component",
            "child"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Spacer": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "An empty space component used for layout and spacing.",
          "properties": {
            "component": {
              "const": "Spacer"
            },
            "width": {
              "oneOf": [
                {
                  "$ref": "./common/common_types.json#/$defs/DynamicString"
                },
                {
                  "$ref": "./common/common_types.json#/$defs/DynamicNumber"
                }
              ],
              "description": "The width of the spacer. If a number is provided, it is treated as pixels. Defaults to '16px'.",
              "default": "16px"
            },
            "height": {
              "oneOf": [
                {
                  "$ref": "./common/common_types.json#/$defs/DynamicString"
                },
                {
                  "$ref": "./common/common_types.json#/$defs/DynamicNumber"
                }
              ],
              "description": "The height of the spacer. If a number is provided, it is treated as pixels. Defaults to '16px'.",
              "default": "16px"
            }
          },
          "required": [
            "component"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "functions": {
    "formatString": {
      "description": "Performs string interpolation of data model values and other functions in the catalog functions list and returns the resulting string. The value string can contain interpolated expressions in the `${expression}` format. Supported expression types include: JSON Pointer paths to the data model (e.g., `${/absolute/path}` or `${relative/path}`), and client-side function calls (e.g., `${now()}`). Function arguments must be literals (quoted strings, numbers, booleans) or nested expressions (e.g., `${formatDate(${/currentDate}, 'MM-dd')}`). To include a literal `${` sequence, escape it as `\\${`.",
      "returnType": "string",
      "parameters": {
        "type": "array",
        "items": [
          {
            "name": "format",
            "description": "The format string.",
            "type": "string"
          }
        ],
        "additionalItems": {
          "$ref": "./common/common_types.json#/$defs/DynamicValue"
        },
        "minItems": 1
      }
    },
    "formatDate": {
      "description": "Formats a timestamp into a string using a pattern.",
      "returnType": "string",
      "parameters": {
        "type": "array",
        "items": [
          {
            "name": "value",
            "$ref": "./common/common_types.json#/$defs/DynamicValue",
            "description": "The date to format."
          },
          {
            "name": "pattern",
            "$ref": "./common/common_types.json#/$defs/DynamicString",
            "description": "A Unicode TR35 date pattern string.\n\nToken Reference:\n- Year: 'yy' (26), 'yyyy' (2026)\n- Month: 'M' (1), 'MM' (01), 'MMM' (Jan), 'MMMM' (January)\n- Day: 'd' (1), 'dd' (01), 'E' (Tue), 'EEEE' (Tuesday)\n- Hour (12h): 'h' (1-12), 'hh' (01-12) - requires 'a' for AM/PM\n- Hour (24h): 'H' (0-23), 'HH' (00-23) - Military Time\n- Minute: 'mm' (00-59)\n- Second: 'ss' (00-59)\n- Period: 'a' (AM/PM)\n\nExamples:\n- 'MMM dd, yyyy' -> 'Jan 16, 2026'\n- 'HH:mm' -> '14:30' (Military)\n- 'h:mm a' -> '2:30 PM'\n- 'EEEE, d MMMM' -> 'Friday, 16 January'"
          }
        ],
        "minItems": 2
      }
    },
