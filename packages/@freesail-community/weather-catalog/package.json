{
  "name": "@freesail-community/weather-catalog",
  "version": "0.6.0",
  "description": "All community built UI component catalogs for Freesail A2UI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepare:catalog": "freesail prepare catalog",
    "build": "tsc",
    "postbuild": "cp src/freesailconfig.json dist/ && cp src/weather-catalog.json dist/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prebuild": "freesail prepare catalog && freesail validate catalog"
  },
  "keywords": [
    "a2ui",
    "freesail",
    "catalog",
    "agent-driven ui",
    "generative ui",
    "ai agent"
  ],
  "peerDependencies": {
    "@freesail/react": "0.4.6",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@freesail/react": "0.4.6",
    "@types/react": "^18.2.0",
    "react": "^18.2.0"
  },
  "dependencies": {
    "freesail": "file:../../freesail",
    "react-markdown": "^10.1.0"
  },
  "author": {
    "name": "Thendral AI Ltd",
    "email": "support@thendral.ai",
    "url": "https://www.thendral.ai"
  },
  "contributors": [
    "Shanmugam Sudalaimuthu"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
