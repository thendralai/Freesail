{
  "components": {
    "WeatherCard": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A comprehensive weather summary card for a location. Key properties: location (required), temperature (required), condition (required, e.g. sunny/cloudy/rainy), unit (C/F, default C), humidity (0-100), windSpeed, windUnit (km/h/mph/m/s), feelsLike, background (CSS color override). User-Writable: false.",
          "properties": {
            "component": {
              "const": "WeatherCard"
            },
            "location": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "City or location name (e.g. 'London', 'New York'). Extract this from the user's request."
            },
            "temperature": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Current temperature value"
            },
            "unit": {
              "type": "string",
              "description": "Temperature unit(C or F)",
              "enum": [
                "C",
                "F"
              ],
              "default": "C"
            },
            "condition": {
              "type": "string",
              "description": "Weather condition",
              "enum": [
                "sunny",
                "cloudy",
                "partly-cloudy",
                "rainy",
                "stormy",
                "snowy",
                "foggy",
                "windy"
              ]
            },
            "humidity": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Humidity percentage (0-100)"
            },
            "windSpeed": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Wind speed value"
            },
            "windUnit": {
              "type": "string",
              "description": "Wind speed unit",
              "enum": [
                "km/h",
                "mph",
                "m/s"
              ],
              "default": "km/h"
            },
            "feelsLike": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Feels-like temperature"
            },
            "background": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Background color override",
              "default": "bgSurface"
            }
          },
          "required": [
            "component",
            "location",
            "temperature",
            "condition"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "ForecastRow": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A single row in a weather forecast, showing the day's conditions. Key properties: day (required, e.g. 'Mon', 'Today'), high (required), low (required), condition (required), unit (C/F, default C), precipitation (chance percentage 0-100). User-Writable: false.",
          "properties": {
            "component": {
              "const": "ForecastRow"
            },
            "day": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Day label (e.g. 'Mon', 'Tuesday', 'Today')"
            },
            "high": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "High temperature"
            },
            "low": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Low temperature"
            },
            "unit": {
              "type": "string",
              "description": "Temperature unit",
              "enum": [
                "C",
                "F"
              ],
              "default": "C"
            },
            "condition": {
              "type": "string",
              "description": "Weather condition for the day",
              "enum": [
                "sunny",
                "cloudy",
                "partly-cloudy",
                "rainy",
                "stormy",
                "snowy",
                "foggy",
                "windy"
              ]
            },
            "precipitation": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Precipitation chance percentage (0-100)"
            }
          },
          "required": [
            "component",
            "day",
            "high",
            "low",
            "condition"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "ForecastPanel": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A container panel that groups ForecastRow children into a titled forecast list. Key properties: children (required, array of ForecastRow IDs or a template), title (default 'Forecast'). User-Writable: false.",
          "properties": {
            "component": {
              "const": "ForecastPanel"
            },
            "title": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Panel title (e.g. '5-Day Forecast')",
              "default": "Forecast"
            },
            "children": {
              "$ref": "../common/common_types.json#/$defs/ChildList",
              "description": "Defines the children. Use an array of strings for a fixed set of children, or a template object to generate children from a data list."
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "TemperatureDisplay": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Renders a temperature value with its unit symbol. Key properties: value (required, numeric temperature), unit (C/F, default C), size (sm/md/lg/xl, default lg), color (CSS color). User-Writable: false.",
          "properties": {
            "component": {
              "const": "TemperatureDisplay"
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Temperature value"
            },
            "unit": {
              "type": "string",
              "description": "Temperature unit",
              "enum": [
                "C",
                "F"
              ],
              "default": "C"
            },
            "size": {
              "type": "string",
              "description": "Display size",
              "enum": [
                "sm",
                "md",
                "lg",
                "xl"
              ],
              "default": "lg"
            },
            "color": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Text color"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "WeatherIcon": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays a weather condition icon. Key properties: condition (required, e.g. sunny/cloudy/rainy/stormy/snowy/foggy/windy), size (sm/md/lg/xl, default md), animated (boolean, default false). User-Writable: false.",
          "properties": {
            "component": {
              "const": "WeatherIcon"
            },
            "condition": {
              "type": "string",
              "description": "Weather condition to display",
              "enum": [
                "sunny",
                "cloudy",
                "partly-cloudy",
                "rainy",
                "stormy",
                "snowy",
                "foggy",
                "windy"
              ]
            },
            "size": {
              "type": "string",
              "description": "Icon size",
              "enum": [
                "sm",
                "md",
                "lg",
                "xl"
              ],
              "default": "md"
            },
            "animated": {
              "$ref": "../common/common_types.json#/$defs/DynamicBoolean",
              "description": "Whether to use subtle animation",
              "default": false
            }
          },
          "required": [
            "component",
            "condition"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "WindIndicator": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays wind speed and direction. Key properties: speed (required), unit (km/h/mph/m/s, default km/h), direction (cardinal, e.g. N/NE/E/SE/S/SW/W/NW), gustSpeed. User-Writable: false.",
          "properties": {
            "component": {
              "const": "WindIndicator"
            },
            "speed": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Wind speed value"
            },
            "unit": {
              "type": "string",
              "description": "Wind speed unit",
              "enum": [
                "km/h",
                "mph",
                "m/s"
              ],
              "default": "km/h"
            },
            "direction": {
              "type": "string",
              "description": "Wind cardinal direction",
              "enum": [
                "N",
                "NE",
                "E",
                "SE",
                "S",
                "SW",
                "W",
                "NW"
              ]
            },
            "gustSpeed": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Gust speed value"
            }
          },
          "required": [
            "component",
            "speed"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "HumidityGauge": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "A gauge that visualizes the current humidity level. Key properties: value (required, percentage 0-100), label (default 'Humidity'). User-Writable: false.",
          "properties": {
            "component": {
              "const": "HumidityGauge"
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "Humidity percentage (0-100)"
            },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Label text",
              "default": "Humidity"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "UVIndex": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays the current UV index with a visual indicator. Key properties: value (required, 0-11+), label (default 'UV Index'). User-Writable: false.",
          "properties": {
            "component": {
              "const": "UVIndex"
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "UV index value (0-11+)"
            },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Label text",
              "default": "UV Index"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "WeatherAlert": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays a weather alert or warning banner. Key properties: severity (required, info/advisory/watch/warning), title (required), message (alert description), expires (expiry time). User-Writable: false.",
          "properties": {
            "component": {
              "const": "WeatherAlert"
            },
            "severity": {
              "type": "string",
              "description": "Alert severity level",
              "enum": [
                "info",
                "advisory",
                "watch",
                "warning"
              ]
            },
            "title": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Alert title"
            },
            "message": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Alert description text"
            },
            "expires": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Expiry time (human-readable or ISO 8601)"
            }
          },
          "required": [
            "component",
            "severity",
            "title"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "SunriseSunset": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Shows sunrise and sunset times with an optional sun position indicator. Key properties: sunrise (required, e.g. '6:32 AM'), sunset (required, e.g. '7:15 PM'), currentTime (for positioning the sun indicator). User-Writable: false.",
          "properties": {
            "component": {
              "const": "SunriseSunset"
            },
            "sunrise": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Sunrise time (e.g. '6:32 AM')"
            },
            "sunset": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Sunset time (e.g. '7:15 PM')"
            },
            "currentTime": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Current time for positioning the sun indicator"
            }
          },
          "required": [
            "component",
            "sunrise",
            "sunset"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "AirQuality": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../common/common_types.json#/$defs/ComponentCommon"
        },
        {
          "$ref": "#/$defs/CatalogComponentCommon"
        },
        {
          "type": "object",
          "description": "Displays the Air Quality Index (AQI) with an optional primary pollutant. Key properties: value (required, AQI 0-500), label (default 'Air Quality'), pollutant (e.g. 'PM2.5', 'O3'). User-Writable: false.",
          "properties": {
            "component": {
              "const": "AirQuality"
            },
            "value": {
              "$ref": "../common/common_types.json#/$defs/DynamicNumber",
              "description": "AQI value (0-500)"
            },
            "label": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Label text",
              "default": "Air Quality"
            },
            "pollutant": {
              "$ref": "../common/common_types.json#/$defs/DynamicString",
              "description": "Primary pollutant (e.g. 'PM2.5', 'O3')"
            }
          },
          "required": [
            "component",
            "value"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "$defs": {
    "CatalogComponentCommon": {
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "description": "The type of component."
        }
      },
      "required": [
        "component"
      ]
    }
  }
}
