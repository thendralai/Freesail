    "build:cli": "tsup --config tsup.cli.config.ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "@freesail/core": "^0.4.6",
    "@freesail/gateway": "^0.4.6",
    "@freesail/react": "^0.4.6",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
