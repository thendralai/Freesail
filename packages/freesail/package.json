{
  "name": "freesail",
  "version": "0.4.6",
  "description": "Unified entry point for Freesail AI SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "freesail": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
