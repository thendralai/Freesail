# Freesail example stack configuration
# Copy this file to .env and fill in your values.
# All variables except GOOGLE_API_KEY are optional.

# ----- Required -----
GOOGLE_API_KEY=your-api-key-here

# ----- Ports -----
# GATEWAY_PORT=3001     # A2UI HTTP/SSE port (default: 3001)
# MCP_PORT=3000         # Agent-facing MCP port (default: 3000)
# AGENT_PORT=3002       # Agent health endpoint (default: 3002)
# UI_PORT=5173          # Vite dev server (default: 5173)

# ----- Gateway logging -----
# LOG_LEVEL=info        # Minimum log level: fatal | error | warn | info | debug
# LOG_FILE=             # Path to log file, e.g. logs/gateway.log (auto-creates dirs)
# LOG_FILTER=           # Space-separated per-subsystem overrides
#                       # Top-level subsystems: express, mcp, session
#                       # Surface sub-categories (dot-notation):
#                       #   session.agent-surface   — surfaces created by the agent (no __ prefix)
#                       #   session.client-surface  — client-managed surfaces (__ prefix)
#                       # Examples:
#                       #   LOG_FILTER=mcp=debug
#                       #   LOG_FILTER=session.agent-surface:debug session.client-surface:warn
#                       #   LOG_FILTER=express:warn session.client-surface:warn
